
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>حاسبة التجهيزات | مجموعة الصخرة 🏗️</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root { --gold: #d4af37; --dark: #111; --white: #ffffff; }
        body { font-family: 'Cairo', sans-serif; background: #f4f4f4; margin: 0; padding-bottom: 120px; }
        
        /* الهيدر بصورة المحل */
        header { background: var(--dark); color: white; padding: 20px; text-align: center; border-bottom: 4px solid var(--gold); }
        .logo-img { width: 100%; max-width: 300px; border-radius: 10px; margin-bottom: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
        
        .container { max-width: 500px; margin: auto; padding: 15px; }
        
        /* كارت المنتج */
        .product-card { 
            background: white; border-radius: 15px; margin-bottom: 20px; overflow: hidden;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1); border: 2px solid transparent; transition: 0.3s;
            cursor: pointer; position: relative;
        }
        .product-card.selected { border-color: var(--gold); transform: translateY(-5px); }
        
        .product-img { width: 100%; height: 200px; object-fit: cover; background: #eee; }
        
        .product-info { padding: 15px; text-align: right; }
        .product-info h3 { margin: 0; font-size: 1.2em; color: var(--dark); }
        .product-info p { margin: 5px 0; color: var(--gold); font-weight: bold; font-size: 1.1em; }
        .product-info small { color: #777; font-size: 0.85em; display: block; margin-top: 5px; }

        /* شريط الحساب تحت */
        .bottom-bar { 
            position: fixed; bottom: 0; left: 0; right: 0; background: var(--dark); 
            color: white; padding: 20px; border-top: 3px solid var(--gold);
            border-radius: 20px 20px 0 0; z-index: 1000;
        }
        .price-row { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .final-total { font-size: 1.4em; color: var(--gold); font-weight: 900; }

        .btn-order { 
            background: #25d366; color: white; width: 100%; border: none; padding: 15px; 
            border-radius: 10px; font-weight: bold; font-size: 1.1em; cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 10px;
        }
        
        .check-icon { position: absolute; top: 10px; left: 10px; background: var(--gold); color: white; 
                      padding: 5px; border-radius: 50%; display: none; }
        .selected .check-icon { display: block; }
    </style>
</head>
<body>

<header>
    <img src="1.1.png" alt="لوحة الصخرة جروب" class="logo-img">
    <h2 style="margin:0">مجموعة الصخرة</h2>
    <p style="margin:5px 0 0; font-size:0.9em">احسب جهازك وشوف الخصم فوراً</p>
</header>

<div class="container">
    <div class="product-card" onclick="toggleItem(this, 1550, 'طقم معالق 48 قطعة')">
        <span class="check-icon">✓</span>
        <img src="1.2.png" class="product-img">
        <div class="product-info">
            <h3>طقم معالق (48 قطعة)</h3>
            <p>1,550 ج.م</p>
            <small>12 معلقة كبيرة، 12 معلقة صغيرة، 12 شوكة كبيرة، 12 شوكة صغيرة</small>
        </div>
    </div>

    <div class="product-card" onclick="toggleItem(this, 850, 'طقم صواني مرايا قطعتين')">
        <span class="check-icon">✓</span>
        <img src="1.3.png" class="product-img">
        <div class="product-info">
            <h3>طقم صواني مرايا (قطعتين)</h3>
            <p>850 ج.م</p>
            <small>تصميم مودرن فخم لتقديم الحلويات والمشروبات</small>
        </div>
    </div>

    <div class="product-card" onclick="toggleItem(this, 1150, 'شياله خزف 3 دور')">
        <span class="check-icon">✓</span>
        <img src="1.4.png" class="product-img">
        <div class="product-info">
            <h3>شيالة خزف (3 دور)</h3>
            <p>1,150 ج.م</p>
            <small>خزف عالي الجودة لتقديم الكحك والبسكويت</small>
        </div>
    </div>
</div>

<div class="bottom-bar">
    <div class="price-row">
        <span>أجهزة مختارة: <span id="count">0</span></span>
        <span id="discount-txt" style="color: #25d366; font-weight: bold;">خصم 0%</span>
    </div>
    <div class="price-row final-total">
        <span>الإجمالي:</span>
        <span id="final-price">0 ج.م</span>
    </div>
    <button class="btn-order" onclick="sendWhatsApp()">
        إرسال الطلب عبر واتساب 💬
    </button>
</div>

<script>
    let cart = [];
    let phone = "201025403293"; // رقمك تم تعديله

    function toggleItem(card, price, name) {
        card.classList.toggle('selected');
        if (card.classList.contains('selected')) {
            cart.push({name, price});
        } else {
            cart = cart.filter(item => item.name !== name);
        }
        updateUI();
    }

    function updateUI() {
        let total = cart.reduce((sum, item) => sum + item.price, 0);
        let discount = 0;
        
        // سيستم الخصم: لو اختار أكتر من قطعة
        if (cart.length >= 3) discount = 10; // خصم 10% لو خد الـ 3 أطقم
        else if (cart.length >= 2) discount = 5;

        let final = total - (total * (discount / 100));

        document.getElementById('count').innerText = cart.length;
        document.getElementById('discount-txt').innerText = `خصم ${discount}%`;
        document.getElementById('final-price').innerText = final.toLocaleString() + " ج.م";
    }

    function sendWhatsApp() {
        if (cart.length === 0) return alert("اختار حاجة الأول يا باشا!");
        
        let text = "طلب جديد من مجموعة الصخرة 🏗️%0A%0A";
        cart.forEach(item => text += `- ${item.name} (${item.price} ج.م)%0A`);
        text += `%0A*الإجمالي بعد الخصم: ${document.getElementById('final-price').innerText}*`;
        
        window.open(`https://wa.me/${phone}?text=${text}`);
    }
</script>

</body>
</html>
